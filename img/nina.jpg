-proxy-min-height="160" data-artboard-proxy-max-height="160"> <div class="t396__carrier" data-artboard-recid="604545175"></div> <div class="t396__filter" data-artboard-recid="604545175"></div> <div class="t396__elem tn-elem tn-elem__6045451751591643842352" data-elem-id="1591643842352" data-elem-type="text" data-field-top-value="90" data-field-left-value="110" data-field-width-value="979" data-field-axisy-value="top" data-field-axisx-value="left" data-field-container-value="grid" data-field-topunits-value="px" data-field-leftunits-value="px" data-field-heightunits-value="" data-field-widthunits-value="px" data-field-fontsize-value="40" data-field-top-res-320-value="45" data-field-left-res-320-value="0" data-field-width-res-320-value="315" data-field-fontsize-res-320-value="25" data-field-top-res-480-value="40" data-field-left-res-480-value="17" data-field-width-res-480-value="447" data-field-fontsize-res-480-value="30" data-field-top-res-640-value="40" data-field-left-res-640-value="46" data-field-width-res-640-value="549" data-field-fontsize-res-640-value="25" data-field-top-res-960-value="50" data-field-left-res-960-value="-10" data-field-fontsize-res-960-value="35" data-fields="top,left,width,height,container,axisx,axisy,widthunits,leftunits,topunits" style="top: 90px; left: 270.5px; width: 979px; height: auto;"> <div class="tn-atom" field="tn_text_1591643842352" style="line-height: 52px;">Tem alguma dúvida?</div> </div> </div> </div> <script>t_onReady(function() {t_onFuncLoad('t396_init',function() {t396_init('604545175');});});</script> <!-- /T396 --> </div> <div id="rec604545176" class="r t-rec t-rec_pt_30 t-rec_pb_90" style="padding-top:30px;padding-bottom:90px;background-color:#ffffff; " data-animationappear="off" data-record-type="585" data-bg-color="#ffffff"> <!-- T585 --> <div class="t585"> <div class="t-container"> <div class="t-col t-col_10 t-prefix_1"> <div class="t585__accordion" data-accordion="false" data-scroll-to-expanded="false"> <div class="t585__wrapper"> <div class="t585__header " style="border-top: 1px solid #15b9a0"> <button type="button" class="t585__trigger-button" aria-controls="accordion1_604545176" aria-expanded="false"> <span class="t585__title t-name t-name_xl" field="li_title__1480611044356">Apenas pessoas de São Paulo podem adotar?</span> <span class="t585__icon"> <span class="t585__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#2d0007"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t585__circle" style="background-color: #ebb000"></span> </span> <span class="t585__icon t585__icon-hover"> <span class="t585__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#2d0007"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t585__circle" style="background-color: #ebb000"></span> </span> </button> </div> <div class="t585__content" id="accordion1_604545176" hidden=""> <div class="t585__textwrapper"> <div class="t585__text t-descr t-descr_xs" field="li_descr__1480611044356">Preferencialmente apenas pessoas de SP/Grande SP adotam no Instituto Caramelo, mas abrimos exceções em casos específicos. Sempre há um animal abandonado, um centro de controle de zoonoses ou uma ONG local em cada cidade com muitos animais a espera de um lar, então dê preferência para quem está próximo de você! Os animais passam por fase de adaptação e estando longe fica mais complicado pra darmos todo suporte necessário nesse período. <br></div> </div> </div> </div> </div> </div> <div class="t-col t-col_10 t-prefix_1"> <div class="t585__accordion" data-accordion="false" data-scroll-to-expanded="false"> <div class="t585__wrapper"> <div class="t585__header " style="border-top: 1px solid #15b9a0"> <button type="button" class="t585__trigger-button" aria-controls="accordion2_604545176" aria-expanded="false"> <span class="t585__title t-name t-name_xl" field="li_title__1480611048442">Só preencher o formulário já garante que serei o adotante do animal que escolhi?</span> <span class="t585__icon"> <span class="t585__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#2d0007"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t585__circle" style="background-color: #ebb000"></span> </span> <span class="t585__icon t585__icon-hover"> <span class="t585__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#2d0007"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t585__circle" style="background-color: #ebb000"></span> </span> </button> </div> <div class="t585__content" id="accordion2_604545176" hidden=""> <div class="t585__textwrapper"> <div class="t585__text t-descr t-descr_xs" field="li_descr__1480611048442">Preencher o formulário é apenas a fase inicial do processo! Em seguida nossa equipe irá verificar a segurança da casa de acordo com o animal escolhido, o suporte que o adotante consegue dar de acordo com as questões de saúde que o animal apresenta, saber se a personalidade do animal é compatível com a rotina da família e em alguns casos muitas pessoas se candidatam para adotar o mesmo animal, então respeitando esses quesitos escolhemos a família que mais se encaixa ao animal e se não for a sua você poderá se candidatar para outro animalzinho!<br></div> </div> </div> </div> </div> </div> <div class="t-col t-col_10 t-prefix_1"> <div class="t585__accordion" data-accordion="false" data-scroll-to-expanded="false"> <div class="t585__wrapper"> <div class="t585__header " style="border-top: 1px solid #15b9a0"> <button type="button" class="t585__trigger-button" aria-controls="accordion3_604545176" aria-expanded="false"> <span class="t585__title t-name t-name_xl" field="li_title__1489600117321">Eu preciso buscar o animal no Instituto ou vocês o trazem até minha casa?</span> <span class="t585__icon"> <span class="t585__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#2d0007"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t585__circle" style="background-color: #ebb000"></span> </span> <span class="t585__icon t585__icon-hover"> <span class="t585__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#2d0007"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t585__circle" style="background-color: #ebb000"></span> </span> </button> </div> <div class="t585__content" id="accordion3_604545176" hidden=""> <div class="t585__textwrapper"> <div class="t585__text t-descr t-descr_xs" field="li_descr__1489600117321">A preferência é que o adotante venha buscar no abrigo, assim tem a oportunidade de conhecer nosso trabalho de perto, tem tempo e disposição de escutar todas as recomendações de nossas veterinárias e caso não seja seu "match" tem a chance de conhecer outro animal alí mesmo.</div> </div> </div> </div> </div> </div> <div class="t-col t-col_10 t-prefix_1"> <div class="t585__accordion" data-accordion="false" data-scroll-to-expanded="false"> <div class="t585__wrapper"> <div class="t585__header " style="border-top: 1px solid #15b9a0"> <button type="button" class="t585__trigger-button" aria-controls="accordion4_604545176" aria-expanded="false"> <span class="t585__title t-name t-name_xl" field="li_title__1591823992649">Posso adotar mais de um animal?</span> <span class="t585__icon"> <span class="t585__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#2d0007"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t585__circle" style="background-color: #ebb000"></span> </span> <span class="t585__icon t585__icon-hover"> <span class="t585__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#2d0007"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t585__circle" style="background-color: #ebb000"></span> </span> </button> </div> <div class="t585__content" id="accordion4_604545176" hidden=""> <div class="t585__textwrapper"> <div class="t585__text t-descr t-descr_xs" field="li_descr__1591823992649">Desde que você tenha as condições financeiras e espaço para isso e os animais escolhidos se aceitem, claro, inclusive dois animais interagindo fazem a adaptação acontecer de forma mais fácil. Assim eles tem a companhia um do outro quando você não estiver em casa!</div> </div> </div> </div> </div> </div> <div class="t-col t-col_10 t-prefix_1"> <div class="t585__accordion" data-accordion="false" data-scroll-to-expanded="false"> <div class="t585__wrapper"> <div class="t585__header " style="border-top: 1px solid #15b9a0"> <button type="button" class="t585__trigger-button" aria-controls="accordion5_604545176" aria-expanded="false"> <span class="t585__title t-name t-name_xl" field="li_title__1591824038651">Essa página é segura? Como posso me certificar?</span> <span class="t585__icon"> <span class="t585__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#2d0007"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t585__circle" style="background-color: #ebb000"></span> </span> <span class="t585__icon t585__icon-hover"> <span class="t585__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#2d0007"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t585__circle" style="background-color: #ebb000"></span> </span> </button> </div> <div class="t585__content" id="accordion5_604545176" hidden=""> <div class="t585__textwrapper"> <div class="t585__text t-descr t-descr_xs" field="li_descr__1591824038651">Sim, essa página está hospedada em ambiente seguro e possui certificado de segurança SSL. Para verificar, observe se o endereço no seu navegador começa com "https" e clique no cadeado ao lado esquerdo.</div> </div> </div> </div> </div> </div> <div class="t-col t-col_10 t-prefix_1"> <div class="t585__accordion" data-accordion="false" data-scroll-to-expanded="false"> <div class="t585__wrapper"> <div class="t585__header " style="border-top: 1px solid #15b9a0"> <button type="button" class="t585__trigger-button" aria-controls="accordion6_604545176" aria-expanded="false"> <span class="t585__title t-name t-name_xl" field="li_title__1591824087493">Caso opte por cancelar a minha doação recorrente no futuro, é possível?</span> <span class="t585__icon"> <span class="t585__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#2d0007"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t585__circle" style="background-color: #ebb000"></span> </span> <span class="t585__icon t585__icon-hover"> <span class="t585__lines"> <svg role="presentation" focusable="false" width="24px" height="24px" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1px" fill="none" fill-rule="evenodd" stroke-linecap="square"> <g transform="translate(1.000000, 1.000000)" stroke="#2d0007"> <path d="M0,11 L22,11"></path> <path d="M11,0 L11,22"></path> </g> </g> </svg> </span> <span class="t585__circle" style="background-color: #ebb000"></span> </span> </button> </div> <div class="t585__content" id="accordion6_604545176" hidden=""> <div class="t585__textwrapper"> <div class="t585__text t-descr t-descr_xs" field="li_descr__1591824087493">Sim, é possível, você pode definir o melhor dia para que a cobrança seja realizada no seu cartão de crédito ou vencimento do boleto. Basta enviar um email para: <strong>suporte@doare.org</strong><strong></strong></div> </div> </div> </div> </div> <div class="t585__border" style="height: 1px; background-color: #15b9a0"></div> </div> </div> </div> <script>t_onReady(function() {t_onFuncLoad('t585_init',function() {t585_init('604545176');});});</script> <style> #rec604545176 .t585__title{font-size:20px;color:#2d0007;font-family:'Alexandria';font-weight:700;}#rec604545176 .t585__text{font-size:15px;color:#2d0007;font-family:'Alexandria';font-weight:300;}</style> </div> <!--footer--> <footer id="t-footer" class="t-records" data-hook="blocks-collection-content-node" data-tilda-project-id="2598993" data-tilda-page-id="15813555" data-tilda-page-alias="footer" data-tilda-formskey="b3abe6333ff66c589cb54a69ecd3f92c" data-tilda-lazy="yes" data-tilda-root-zone="one" data-tilda-project-headcode="yes" data-tilda-project-country="BR"> <div id="rec315221692" class="r t-rec" style="opacity: 1;" data-animationappear="off" data-record-type="312"> <div class="t312"> <div class="t312__popup" style=""> <div class="t312__bg" style=""></div> <button type="button" class="t312__close-button t312__close" aria-label="Close dialog window" style=""> <svg role="presentation" class="t-popup__close-icon" width="23px" height="23px" viewBox="0 0 23 23" version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"> <g stroke="none" stroke-width="1" fill="#fff" fill-rule="evenodd"> <rect transform="translate(11.313708, 11.3137